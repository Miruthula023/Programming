import pygame
import sys

pygame.init()

screen = pygame.display.set_mode((800,700))
pygame.display.set_caption("shapes")

run = True

while run:
	for event in pygame.event.get():
		if event.type == pygame.QUIT:
			run = False

	screen.fill((0,12,0))
	pygame.display.update()

	pygame.draw.rect((225,225,225),(12,4,56,77))
pygame.quit()
sys.exit()
